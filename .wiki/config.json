{
  "version": 1,
  "title": "OpenTDS Wiki",
  "domain": "Open Transaction Data Standard — knowledge base for transaction data models, protocols, and ecosystem",
  "timezone": "UTC",
  "paths": {
    "raw": "raw",
    "wiki": "wiki",
    "meta": "meta"
  },
  "pageTypes": {
    "source": "wiki/sources",
    "concept": "wiki/concepts",
    "entity": "wiki/entities",
    "synthesis": "wiki/syntheses",
    "analysis": "wiki/analyses"
  },
  "templates": {
    "source": ".wiki/templates/source.md",
    "concept": ".wiki/templates/concept.md",
    "entity": ".wiki/templates/entity.md",
    "synthesis": ".wiki/templates/synthesis.md",
    "analysis": ".wiki/templates/analysis.md"
  },
  "linkStyle": "wikilink-folder-qualified",
  "citationStyle": "source-page-id-link",
  "protect": [
    "raw/**",
    "meta/registry.json",
    "meta/backlinks.json",
    "meta/events.jsonl",
    "meta/index.md",
    "meta/log.md",
    "meta/lint-report.md"
  ],
  "search": {
    "defaultLimit": 10
  }
}
